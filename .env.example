NODE_ENV=production
ADMIN_PASSWORD=change-me
DATABASE_PATH=./glean.db
NUXT_PUBLIC_APP_NAME=Glean
GLEAN_SESSION_TOKEN=

# Optional AI (strict free-only default)
AI_PROVIDER=auto
AI_COST_MODE=free-only
AI_EMBED_PROVIDER=gemini

AI_OPENROUTER_API_KEY=
AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_OPENROUTER_CLASSIFY_MODEL=nvidia/nemotron-3-super-120b-a12b:free
AI_OPENROUTER_SUMMARY_MODEL=nvidia/nemotron-3-super-120b-a12b:free
AI_OPENROUTER_CLASSIFY_FALLBACKS=nvidia/nemotron-3-super-120b-a12b:free,openrouter/hunter-alpha,stepfun/step-3.5-flash:free,openrouter/free
AI_OPENROUTER_SUMMARY_FALLBACKS=nvidia/nemotron-3-super-120b-a12b:free,openrouter/hunter-alpha,stepfun/step-3.5-flash:free,openrouter/free
AI_ALLOW_OPENROUTER_EMBED=false

GEMINI_API_KEY=
AI_GEMINI_EMBED_MODEL=gemini-embedding-2-preview
AI_GEMINI_EMBED_DIMENSIONS=768
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

AI_CLASSIFY_PAYLOAD_TOKENS=1200
AI_SUMMARIZE_PAYLOAD_TOKENS=2500
AI_EMBED_PAYLOAD_TOKENS=1000
